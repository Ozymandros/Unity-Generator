{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "A: Electron",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev:electron:live",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Backend (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "preLaunchTask": "kill-port-35421",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--port",
        "35421",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "justMyCode": true
    },
    {
      "name": "Frontend (Vite)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "B: Full stack (Vite + uvicorn)",
      "configurations": [
        "Backend (uvicorn)",
        "Frontend (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "C: Full stack + Electron",
      "configurations": [
        "Backend (uvicorn)",
        "Frontend (Vite)",
        "A: Electron"
      ],
      "stopAll": true
    }
  ]
}
