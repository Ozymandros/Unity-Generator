{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "35421"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "justMyCode": true
    },
    {
      "name": "Frontend (Vite Server)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    // {
    //   "name": "Frontend (Browser)",
    //   "type": "chrome",
    //   "request": "launch",
    //   "url": "http://localhost:5173", // Make sure this matches your Vite port
    //   "webRoot": "${workspaceFolder}/frontend",
    //   "sourceMapPathOverrides": {
    //     "webpack:///./src/*": "${webRoot}/src/*"
    //   }
    // },
    {
      "name": "Electron App",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:electron; Read-Host 'Press Enter to close'",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Debug: Full Stack",
      "configurations": [
        "Backend (FastAPI)",
        "Frontend (Vite Server)",
        "Electron App"
      ],
      "stopAll": true
    }
  ]
}