{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./frontend/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "frontend/src/**/*.js",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.vue",
    "frontend/env.d.ts"
  ],
  "exclude": ["node_modules", "**/node_modules"]
}
