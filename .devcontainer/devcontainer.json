{
  "name": "Unity-Generator Devcontainer",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces/Unity-Generator",
  "runServices": ["backend", "frontend"],
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "Vue.volar"
      ]
    }
  },
  "postCreateCommand": "cd backend && pip install -r requirements.txt"
}
