{
  "name": "Unity-Generator Devcontainer",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces/Unity-Generator",
  "runServices": ["backend", "frontend"],
  "shutdownAction": "stopCompose",
  "forwardPorts": [8000, 5173, 5678],
  "portsAttributes": {
    "8000": {
      "label": "Backend (FastAPI)",
      "protocol": "http",
      "onAutoForward": "openBrowserOnce"
    },
    "5173": {
      "label": "Frontend (Vite)",
      "protocol": "http",
      "onAutoForward": "openBrowserOnce"
    },
    "5678": {
      "label": "Python Debugpy"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-containers",
        "ms-semantic-kernel.semantic-kernel",
        "Vue.volar"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y nodejs npm python3 python3-pip && cd backend && pip install -r requirements.txt"
}
