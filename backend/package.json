{
  "name": "unity-generator-backend",
  "version": "0.3.0",
  "description": "Backend for Unity Generator",
  "private": true,
  "scripts": {
    "typecheck": "pyright --project ..",
    "lint": "ruff check . --config pyproject.toml",
    "lint:fix": "ruff check . --config pyproject.toml --fix",
    "format": "ruff format . --config pyproject.toml",
    "format:check": "ruff format . --config pyproject.toml --check",
    "test": "pytest -c pytest.ini",
    "build": "pip install -r requirements.txt",
    "start": "docker compose -f ../docker-compose.yml up --build",
    "dev": "python -m uvicorn app.main:app --reload --port 8000"
  }
}
