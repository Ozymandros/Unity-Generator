{
    "version": "0.1.1",
    "description": "Desktop app to generate Unity assets using AI (Tauri + FastAPI)",
    "name": "unity-generator",
    "private": true,
    "scripts": {
        "// --- Build & Distribution ---": "",
        "build:backend": "powershell -ExecutionPolicy Bypass -File scripts/build_backend.ps1",
        "build:frontend": "pnpm --dir frontend build",
        "package": "pnpm run clean && pnpm run build:backend && pnpm run tauri:build",
        "// --- Development ---": "",
        "dev": "pnpm --dir frontend dev:tauri",
        "tauri": "pnpm --dir frontend tauri",
        "tauri:build": "pnpm --dir frontend tauri build",
        "// --- Quality Control: Frontend & Backend ---": "",
        "lint:backend": "pnpm --dir backend lint",
        "lint:backend:fix": "pnpm --dir backend lint:fix",
        "lint:frontend": "pnpm --dir frontend lint",
        "lint:frontend:fix": "pnpm --dir frontend lint",
        "test:backend": "pnpm --dir backend test",
        "test:frontend": "pnpm --dir frontend test",
        "typecheck:backend": "pnpm --dir backend typecheck",
        "typecheck:frontend": "pnpm --dir frontend typecheck",
        "// --- Quality Control: Unified ---": "",
        "check:all": "pnpm lint:all && pnpm typecheck:all && pnpm test:all",
        "check:all:e2e": "pnpm lint:all && pnpm typecheck:all && pnpm test:all && pnpm --dir frontend test:e2e",
        "lint:all": "pnpm lint:backend && pnpm lint:frontend",
        "test:all": "pnpm test:backend && pnpm test:frontend",
        "typecheck:all": "pnpm typecheck:backend && pnpm typecheck:frontend",
        "// --- Project Lifecycle & Utilities ---": "",
        "setup": "pnpm install && pnpm --dir frontend install && pip install -r backend/requirements.txt",
        "clean": "pnpm run clean:backend && pnpm run clean:frontend",
        "clean:backend": "powershell -Command \"Remove-Item -Recurse -Force backend/dist,backend/build,frontend/src-tauri/binaries/backend-* -ErrorAction SilentlyContinue\"",
        "clean:frontend": "pnpm --dir frontend run clean"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.4",
        "jsdom": "^28.1.0",
        "vitest": "^4.0.18"
    }
}
