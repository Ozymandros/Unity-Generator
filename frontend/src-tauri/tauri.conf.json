{
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Unity Generator",
    "version": "0.9.1"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.unity.generator",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "../../backend/dist/unity-generator-backend.exe",
        "../../backend/dist/unity-generator-backend"
      ]
    },
    "windows": [
      {
        "title": "Unity Generator",
        "width": 1280,
        "height": 800
      }
    ],
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    }
  }
}
