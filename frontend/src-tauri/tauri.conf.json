{
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Unity Generator",
    "version": "0.1.1"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.unity.generator",
      "externalBin": [
        "../backend/dist/unity-generator-backend"
      ]
    },
    "windows": [
      {
        "title": "Unity Generator",
        "width": 1280,
        "height": 800
      }
    ],
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    }
  }
}
