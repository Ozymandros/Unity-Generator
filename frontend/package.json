{
  "name": "unity-generator-frontend",
  "description": "Frontend for Unity Generator",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-pattern dist/** --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-pattern dist/**",
    "test": "cross-env NODE_OPTIONS=--no-webstorage vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-webstorage vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--no-webstorage vitest run --coverage",
    "test:e2e": "node scripts/run-playwright-e2e.mjs",
    "test:smoke": "node scripts/run-playwright-e2e.mjs smoke.spec.ts",
    "test:packaged": "node scripts/run-playwright-e2e.mjs packaged-app.spec.ts"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vuetify/v0": "^0.1.2",
    "pinia": "^3.0.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "latest",
    "vuetify": "^3.12.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@eslint/js": "9.39.2",
    "@playwright/test": "latest",
    "@vitejs/plugin-vue": "latest",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10",
    "eslint-plugin-vue": "^9",
    "globals": "^17.3.0",
    "jsdom": "^24.0.0",
    "msw": "^2.12.10",
    "playwright": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8",
    "vite": "latest",
    "vitest": "latest",
    "vue-eslint-parser": "^10.2.0"
  }
}
