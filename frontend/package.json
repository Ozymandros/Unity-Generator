    "@vitejs/plugin-vue": "latest",
    "eslint": "^9",
    "eslint-plugin-vue": "^9",
    "globals": "^17.3.0",
    "playwright": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8",
    "vite": "latest",
    "vitest": "latest",
    "vue-eslint-parser": "^10.2.0"
